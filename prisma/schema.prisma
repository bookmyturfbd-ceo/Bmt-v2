generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Division {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  cities    City[]
  turfs     Turf[]
  wbtTurfs  WbtTurf[]

  @@map("divisions")
}

model City {
  id         String    @id @default(cuid())
  name       String
  divisionId String
  createdAt  DateTime  @default(now())
  division   Division  @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  turfs      Turf[]
  wbtTurfs   WbtTurf[]
  homeTeams  Team[]    @relation("TeamHomeAreas")

  @@unique([name, divisionId])
  @@map("cities")
}

model Sport {
  id         String      @id @default(cuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  category   String      @default("Other")
  turfSports TurfSport[]

  @@map("sports")
}

model Amenity {
  id            String        @id @default(cuid())
  name          String        @unique
  createdAt     DateTime      @default(now())
  turfAmenities TurfAmenity[]

  @@map("amenities")
}

model Player {
  id                      String               @id @default(cuid())
  fullName                String
  email                   String               @unique
  phone                   String               @default("")
  password                String
  joinedAt                DateTime             @default(now())
  walletBalance           Float                @default(0)
  loyaltyPoints           Int                  @default(0)
  level                   Int                  @default(1)
  levelProgress           Float                @default(0)
  avatarUrl               String?
  banStatus               BanStatus            @default(none)
  banUntil                DateTime?
  banReason               String?
  mmr                     Int                  @default(1000)
  cricketMmr              Int                  @default(1000)
  footballMmr             Int                  @default(1000)
  tournamentCricketMmr    Int                  @default(1000)
  tournamentFootballMmr   Int                  @default(1000)
  battingPerformances     BattingPerformance[]
  bookingSplits           BookingSplit[]
  bookings                Booking[]
  bowlingPerformances     BowlingPerformance[]
  chatMessages            MatchChatMessage[]   @relation("PlayerChatMessages")
  proposedSingleScorerFor Match[]              @relation("MatchProposedScorer")
  playGroupChats          PlayGroupChat[]
  playGroupMemberships    PlayGroupMember[]
  playJoinRequests        PlayJoinRequest[]
  playRequestChats        PlayRequestChat[]
  badges                  PlayerBadge[]
  matchStats              PlayerMatchStat[]
  reels                   Reel[]
  reviews                 Review[]
  shopOrders              ShopOrder[]
  teamAnnouncements       TeamAnnouncement[]
  teamMemberships         TeamMember[]
  ownedTeams              Team[]               @relation("TeamOwner")
  walletRequests          WalletRequest[]

  @@map("players")
}

model PlayerBadge {
  id          String   @id @default(cuid())
  playerId    String
  title       String
  description String?
  icon        String
  earnedAt    DateTime @default(now())
  isShowcased Boolean  @default(false)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_badges")
}

model Owner {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  phone             String             @default("")
  contactPerson     String?
  password          String
  joinedAt          DateTime           @default(now())
  walletBalance     Float              @default(0)
  pendingBmtCut     Float              @default(0)
  isCoach           Boolean            @default(false)
  financeLock       FinanceLock?
  ledgerConclusions LedgerConclusion[]
  ledgerEntries     LedgerEntry[]
  payouts           Payout[]
  turfs             Turf[]

  @@map("owners")
}

model FinanceLock {
  id       String @id @default(cuid())
  ownerId  String @unique
  password String
  owner    Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("finance_locks")
}

model Turf {
  id                String             @id @default(cuid())
  name              String
  ownerId           String
  divisionId        String
  cityId            String
  area              String?
  lat               Float?
  lng               Float?
  mapLink           String?
  logoUrl           String?
  imageUrls         String[]           @default([])
  status            TurfStatus         @default(pending)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  revenueModelType  RevenueModelType?
  revenueModelValue Float?
  rules             String?
  coachType         String?
  isCoachProfile    Boolean            @default(false)
  discounts         Discount[]
  grounds           Ground[]
  ledgerConclusions LedgerConclusion[]
  ledgerEntries     LedgerEntry[]
  reviews           Review[]
  amenities         TurfAmenity[]
  sports            TurfSport[]
  city              City               @relation(fields: [cityId], references: [id])
  division          Division           @relation(fields: [divisionId], references: [id])
  owner             Owner              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  homeTeams         Team[]             @relation("TeamHomeTurfs")

  @@map("turfs")
}

model Review {
  id         String   @id @default(cuid())
  turfId     String
  playerId   String?
  playerName String?
  rating     Float
  comment    String?
  createdAt  DateTime @default(now())
  player     Player?  @relation(fields: [playerId], references: [id])
  turf       Turf     @relation(fields: [turfId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model TurfSport {
  turfId  String
  sportId String
  sport   Sport  @relation(fields: [sportId], references: [id], onDelete: Cascade)
  turf    Turf   @relation(fields: [turfId], references: [id], onDelete: Cascade)

  @@id([turfId, sportId])
  @@map("turf_sports")
}

model TurfAmenity {
  turfId    String
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  turf      Turf    @relation(fields: [turfId], references: [id], onDelete: Cascade)

  @@id([turfId, amenityId])
  @@map("turf_amenities")
}

model Ground {
  id     String @id @default(cuid())
  turfId String
  name   String
  turf   Turf   @relation(fields: [turfId], references: [id], onDelete: Cascade)
  slots  Slot[]

  @@map("grounds")
}

model Slot {
  id           String       @id @default(cuid())
  turfId       String
  groundId     String
  startTime    String
  endTime      String
  timeCategory TimeCategory
  days         String[]     @default([])
  price        Float
  status       SlotStatus   @default(available)
  sports       String[]     @default([])
  bookings     Booking[]
  ground       Ground       @relation(fields: [groundId], references: [id], onDelete: Cascade)

  @@map("slots")
}

model Booking {
  id               String         @id @default(cuid())
  playerId         String
  slotId           String
  turfId           String
  date             String
  price            Float
  ownerShare       Float          @default(0)
  bmtCut           Float          @default(0)
  status           BookingStatus  @default(confirmed)
  createdAt        DateTime       @default(now())
  paymentProofUrl  String?
  selectedSport    String?
  bookingCode      String?
  notes            String?
  source           String?
  groupBookingCode String?
  groupId          String?
  splits           BookingSplit[]
  player           Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  slot             Slot           @relation(fields: [slotId], references: [id])

  @@map("bookings")
}

model BookingSplit {
  id        String  @id @default(cuid())
  bookingId String
  playerId  String
  amount    Float
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  player    Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("booking_splits")
}

model Discount {
  id          String       @id @default(cuid())
  turfId      String
  code        String
  type        DiscountType
  value       Float
  minBookings Int?
  maxUses     Int?
  usedCount   Int          @default(0)
  active      Boolean      @default(true)
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  groundId    String?
  targetDays  String[]     @default([])
  targetSport String?
  targetTimes String[]     @default([])
  turf        Turf         @relation(fields: [turfId], references: [id], onDelete: Cascade)

  @@unique([turfId, code])
  @@map("discounts")
}

model LedgerEntry {
  id          String          @id @default(cuid())
  turfId      String
  ownerId     String
  month       String
  type        LedgerEntryType
  category    LedgerCategory
  description String
  amount      Float
  createdAt   DateTime        @default(now())
  owner       Owner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  turf        Turf            @relation(fields: [turfId], references: [id], onDelete: Cascade)

  @@map("ledger_entries")
}

model LedgerConclusion {
  id             String   @id @default(cuid())
  turfId         String
  ownerId        String
  month          String
  totalAppIncome Float    @default(0)
  totalWalkIn    Float    @default(0)
  totalCost      Float    @default(0)
  netProfit      Float    @default(0)
  concludedAt    DateTime @default(now())
  owner          Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  turf           Turf     @relation(fields: [turfId], references: [id], onDelete: Cascade)

  @@unique([ownerId, month])
  @@map("ledger_conclusions")
}

model Payout {
  id        String       @id @default(cuid())
  ownerId   String
  ownerName String
  turfName  String
  amount    Float
  bmtCut    Float        @default(0)
  date      String
  method    PayoutMethod
  txId      String?
  proofUrl  String?
  createdAt DateTime     @default(now())
  owner     Owner        @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("payouts")
}

model WalletRequest {
  id            String               @id @default(cuid())
  playerId      String
  playerName    String
  amount        Float
  method        WalletRechargeMethod
  screenshotUrl String?
  status        WalletRequestStatus  @default(pending)
  createdAt     DateTime             @default(now())
  reviewedAt    DateTime?
  note          String?
  player        Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("wallet_requests")
}

model PaymentMethod {
  id          String               @id @default(cuid())
  type        WalletRechargeMethod @unique
  number      String
  accountType String
  updatedAt   DateTime             @updatedAt

  @@map("payment_methods")
}

model InviteToken {
  id        String     @id @default(cuid())
  token     String     @unique
  contact   String
  role      InviteRole
  issuedAt  DateTime   @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  usedBy    String?

  @@map("invite_tokens")
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model MonthlyFee {
  id        String    @id @default(cuid())
  turfId    String
  ownerId   String
  turfName  String
  ownerName String
  month     String
  amount    Float
  paid      Boolean   @default(false)
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([turfId, month])
  @@map("monthly_fees")
}

model BannerSlide {
  id        String   @id @default(cuid())
  imageUrl  String
  ctaText   String?
  ctaLink   String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("banner_slides")
}

model CarouselSettings {
  id         String  @id @default("singleton")
  autoSlide  Boolean @default(true)
  intervalMs Int     @default(3500)

  @@map("carousel_settings")
}

model TeamAnnouncement {
  id        String   @id @default(cuid())
  teamId    String
  authorId  String
  title     String
  content   String
  createdAt DateTime @default(now())
  author    Player   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_announcements")
}

model Team {
  id                    String                 @id @default(cuid())
  name                  String                 @unique
  logoUrl               String?
  ownerId               String
  createdAt             DateTime               @default(now())
  level                 Int                    @default(1)
  sportType             SportType
  teamMmr               Int                    @default(1000)
  xp                    Int                    @default(0)
  isSubscribed          Boolean                @default(false)
  formation             String?
  cricketMmr            Int                    @default(1000)
  footballMmr           Int                    @default(1000)
  teamType              TeamType               @default(REGULAR)
  disputes              ChallengeDispute[]
  challengeSubscription ChallengeSubscription?
  matchesAsTeamA        Match[]                @relation("TeamAMatches")
  matchesAsTeamB        Match[]                @relation("TeamBMatches")
  playerStats           PlayerMatchStat[]
  announcements         TeamAnnouncement[]
  members               TeamMember[]
  owner                 Player                 @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  homeAreas             City[]                 @relation("TeamHomeAreas")
  homeTurfs             Turf[]                 @relation("TeamHomeTurfs")

  @@map("teams")
}

model TeamMember {
  id            String   @id @default(cuid())
  teamId        String
  playerId      String
  role          TeamRole @default(member)
  joinedAt      DateTime @default(now())
  isStarter     Boolean  @default(false)
  pitchPosition Int?
  sportRole     String?
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
  @@map("team_members")
}

model Match {
  id                     String                 @id @default(cuid())
  teamA_Id               String
  teamB_Id               String
  status                 MatchStatus            @default(PENDING)
  scoreA                 Int                    @default(0)
  scoreB                 Int                    @default(0)
  winnerId               String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  mmrChangeA             Int                    @default(0)
  mmrChangeB             Int                    @default(0)
  seasonId               String?
  bookingIdA             String?
  bookingIdB             String?
  finalOutcome           String?
  formationA             String?
  formationB             String?
  goalsA                 Int?
  goalsB                 Int?
  matchDate              String?
  matchEndedByA          Boolean                @default(false)
  matchEndedByB          Boolean                @default(false)
  matchStartedByA        Boolean                @default(false)
  matchStartedByB        Boolean                @default(false)
  oversA                 Float?
  oversB                 Float?
  rosterLockedA          Boolean                @default(false)
  rosterLockedB          Boolean                @default(false)
  runsA                  Int?
  runsB                  Int?
  scoreSubmittedByA      Boolean                @default(false)
  scoreSubmittedByB      Boolean                @default(false)
  selectedSlotId         String?
  submittedScoreA        Int?
  submittedScoreA2       Int?
  submittedScoreB        Int?
  submittedScoreB2       Int?
  venueBookedAt          DateTime?
  wicketsA               Int?
  wicketsB               Int?
  bookingCode            String?
  agreedByA              Boolean                @default(false)
  agreedByB              Boolean                @default(false)
  resultSeenByA          Boolean                @default(false)
  resultSeenByB          Boolean                @default(false)
  agreedOvers            Int?
  badgeBonusApplied      Boolean                @default(false)
  scoreModeAgreed        Boolean                @default(false)
  scoreModeRequestedBy   String?
  scoringMode            ScoringMode            @default(LIVE)
  venueType              VenueType?
  wbtCouponCode          String?
  wbtCouponDiscount      Float                  @default(0)
  wbtFrom                String?
  wbtPaymentA            Boolean                @default(false)
  wbtPaymentB            Boolean                @default(false)
  wbtTo                  String?
  wbtTurfId              String?
  wbtTurfName            String?
  venueConfirmedByB      Boolean                @default(false)
  proposedSingleScorerId String?
  disputes               ChallengeDispute[]
  cricketInnings         CricketInnings[]
  cricketToss            CricketToss?
  chatMessages           MatchChatMessage[]
  events                 MatchEvent[]
  halfTime               MatchHalfTime?
  rosterPicks            MatchRosterPick[]
  scorers                MatchScorer[]
  signOffs               MatchSignOff[]
  venueSuggestions       MatchVenueSuggestion[]
  proposedSingleScorer   Player?                @relation("MatchProposedScorer", fields: [proposedSingleScorerId], references: [id])
  season                 ChallengeSeason?       @relation(fields: [seasonId], references: [id])
  teamA                  Team                   @relation("TeamAMatches", fields: [teamA_Id], references: [id])
  teamB                  Team                   @relation("TeamBMatches", fields: [teamB_Id], references: [id])
  playerStats            PlayerMatchStat[]

  @@map("matches")
}

model PlayerMatchStat {
  id         String    @id @default(cuid())
  matchId    String
  playerId   String
  teamId     String
  badge      BadgeType @default(NONE)
  goals      Int       @default(0)
  assists    Int       @default(0)
  runs       Int       @default(0)
  wickets    Int       @default(0)
  createdAt  DateTime  @default(now())
  mmrChange  Int       @default(0)
  overs      Float     @default(0)
  redCard    Boolean   @default(false)
  yellowCard Boolean   @default(false)
  badgeBonus Int       @default(0)
  match      Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player     Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@map("player_match_stats")
}

model MatchRosterPick {
  id        String  @id @default(cuid())
  matchId   String
  teamId    String
  memberId  String
  isStarter Boolean @default(true)
  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, memberId])
  @@map("match_roster_picks")
}

model MatchVenueSuggestion {
  id       String @id @default(cuid())
  matchId  String
  turfId   String
  slotId   String
  date     String
  priority Int
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("match_venue_suggestions")
}

model MatchChatMessage {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  teamId    String
  message   String
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation("PlayerChatMessages", fields: [playerId], references: [id], onDelete: Cascade)

  @@map("match_chat_messages")
}

model MatchScorer {
  id         String   @id @default(cuid())
  matchId    String
  teamId     String
  playerId   String
  assignedAt DateTime @default(now())
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamId])
  @@map("match_scorers")
}

model MatchEvent {
  id               String         @id @default(cuid())
  matchId          String
  type             MatchEventType
  teamId           String
  playerId         String?
  assistPlayerId   String?
  playerOnId       String?
  minute           Int
  status           EventStatus    @default(PENDING)
  disputedByTeamId String?
  resolvedAt       DateTime?
  resolution       String?
  createdAt        DateTime       @default(now())
  match            Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("match_events")
}

model MatchSignOff {
  id          String   @id @default(cuid())
  matchId     String
  teamId      String
  signedOffAt DateTime @default(now())
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamId])
  @@map("match_sign_offs")
}

model MatchHalfTime {
  id          String    @id @default(cuid())
  matchId     String    @unique
  calledByA   Boolean   @default(false)
  calledByB   Boolean   @default(false)
  confirmedAt DateTime?
  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("match_halftimes")
}

model ChallengeSeason {
  id        String   @id @default(cuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  matches   Match[]

  @@map("challenge_seasons")
}

model ChallengeSubscription {
  id             String    @id @default(cuid())
  teamId         String    @unique
  active         Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  gracePeriodEnd DateTime?
  team           Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("challenge_subscriptions")
}

model ChallengePayment {
  id        String   @id @default(cuid())
  teamId    String
  ownerId   String
  amount    Float
  createdAt DateTime @default(now())

  @@map("challenge_payments")
}

model ChallengeDispute {
  id        String        @id @default(cuid())
  matchId   String
  teamId    String
  reason    String
  status    DisputeStatus @default(PENDING)
  createdAt DateTime      @default(now())
  match     Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team      Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("challenge_disputes")
}

model ChallengeMarketConfig {
  id               String   @id @default("singleton")
  monthlyFee       Int      @default(500)
  updatedAt        DateTime @updatedAt
  updatedByAdminId String?

  @@map("challenge_market_config")
}

model ShopCarouselSlide {
  id        String   @id @default(cuid())
  imageUrl  String
  ctaText   String?
  ctaLink   String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("shop_carousel_slides")
}

model ShopCarouselSettings {
  id         String   @id @default("singleton")
  autoSlide  Boolean  @default(true)
  intervalMs Int      @default(3500)
  slideType  String   @default("auto")
  updatedAt  DateTime @updatedAt

  @@map("shop_carousel_settings")
}

model ShopCategory {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  parentId     String?
  order        Int            @default(0)
  imageUrl     String?
  createdAt    DateTime       @default(now())
  sizeChartUrl String?
  parent       ShopCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children     ShopCategory[] @relation("SubCategories")
  products     ShopProduct[]

  @@map("shop_categories")
}

model ShopProduct {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  categoryId     String
  mainImage      String
  galleryImages  String[]          @default([])
  description    String?
  seoTitle       String?
  seoDescription String?
  productCost    Float             @default(0)
  marketingCost  Float             @default(0)
  status         String            @default("active")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  orderItems     ShopOrderItem[]
  sizes          ShopProductSize[]
  category       ShopCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("shop_products")
}

model ShopProductSize {
  id        String      @id @default(cuid())
  productId String
  label     String
  basePrice Float
  salePrice Float?
  quantity  Int         @default(0)
  product   ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("shop_product_sizes")
}

model PlayGroup {
  id            String             @id @default(cuid())
  ownerId       String
  createdAt     DateTime           @default(now())
  name          String             @default("My Group")
  sport         String?
  chatMsgs      PlayGroupChat[]
  members       PlayGroupMember[]
  listings      PlayListing[]
  splitRequests PlaySplitRequest[]

  @@map("play_groups")
}

model PlayGroupMember {
  id            String             @id @default(cuid())
  groupId       String
  playerId      String
  splitAmount   Float              @default(0)
  joinedAt      DateTime           @default(now())
  group         PlayGroup          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  player        Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  splitRequests PlaySplitRequest[]

  @@unique([groupId, playerId])
  @@map("play_group_members")
}

model PlaySplitRequest {
  id        String          @id @default(cuid())
  groupId   String
  memberId  String
  amount    Float
  status    PlaySplitStatus @default(PENDING)
  createdAt DateTime        @default(now())
  group     PlayGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member    PlayGroupMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("play_split_requests")
}

model PlayListing {
  id              String            @id @default(cuid())
  groupId         String
  sport           String?
  playersNeeded   Int               @default(1)
  description     String?
  date            String?
  timeSlot        String?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  minCricketRank  Int?
  minFootballRank Int?
  turfId          String?
  turfName        String?
  requests        PlayJoinRequest[]
  group           PlayGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("play_listings")
}

model PlayJoinRequest {
  id        String            @id @default(cuid())
  listingId String
  playerId  String
  status    PlayJoinStatus    @default(PENDING)
  createdAt DateTime          @default(now())
  listing   PlayListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  player    Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  chatMsgs  PlayRequestChat[]

  @@unique([listingId, playerId])
  @@map("play_join_requests")
}

model PlayGroupChat {
  id        String    @id @default(cuid())
  groupId   String
  playerId  String
  message   String
  createdAt DateTime  @default(now())
  group     PlayGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("play_group_chat")
}

model PlayRequestChat {
  id        String          @id @default(cuid())
  requestId String
  playerId  String
  message   String
  createdAt DateTime        @default(now())
  player    Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  request   PlayJoinRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("play_request_chat")
}

model ShopOrder {
  id             String          @id @default(cuid())
  playerId       String?
  customerName   String
  customerPhone  String
  customerEmail  String?
  address        String
  district       String
  paymentMethod  String
  deliveryCharge Float
  subtotal       Float
  total          Float
  status         String          @default("pending")
  createdAt      DateTime        @default(now())
  items          ShopOrderItem[]
  player         Player?         @relation(fields: [playerId], references: [id])

  @@map("shop_orders")
}

model ShopOrderItem {
  id        String      @id @default(cuid())
  orderId   String
  productId String
  sizeLabel String
  quantity  Int
  price     Float
  order     ShopOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   ShopProduct @relation(fields: [productId], references: [id])

  @@map("shop_order_items")
}

model CricketToss {
  id                 String    @id @default(cuid())
  matchId            String    @unique
  winnerTeamId       String?
  electedTo          String?
  recordedByPlayerId String?
  confirmedByA       Boolean   @default(false)
  confirmedByB       Boolean   @default(false)
  confirmedAt        DateTime?
  createdAt          DateTime  @default(now())
  proposedOversA     Int?
  proposedOversB     Int?
  calledByTeamId     String?
  coinLandedOn       String?
  tossCall           String?
  match              Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("cricket_tosses")
}

model CricketInnings {
  id                  String                @id @default(cuid())
  matchId             String
  inningsNumber       Int
  battingTeamId       String
  bowlingTeamId       String
  totalRuns           Int                   @default(0)
  totalWickets        Int                   @default(0)
  totalOvers          Float                 @default(0)
  extras              Int                   @default(0)
  wides               Int                   @default(0)
  noBalls             Int                   @default(0)
  battingOrder        Json                  @default("[]")
  openingBowlerId     String?
  currentStrikerId    String?
  currentNonStrikerId String?
  currentBowlerId     String?
  currentOverNumber   Int                   @default(1)
  status              InningsStatus         @default(PENDING)
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime              @default(now())
  battingPerfs        BattingPerformance[]
  bowlingPerfs        BowlingPerformance[]
  deliveries          CricketDelivery[]
  match               Match                 @relation(fields: [matchId], references: [id], onDelete: Cascade)
  signOffs            CricketMatchSignOff[]
  overs               CricketOver[]

  @@unique([matchId, inningsNumber])
  @@map("cricket_innings")
}

model CricketOver {
  id                 String            @id @default(cuid())
  inningsId          String
  matchId            String
  overNumber         Int
  bowlerId           String
  runs               Int               @default(0)
  wickets            Int               @default(0)
  wides              Int               @default(0)
  noBalls            Int               @default(0)
  legalBalls         Int               @default(0)
  status             OverStatus        @default(PENDING)
  confirmedByBatting Boolean           @default(false)
  confirmedByBowling Boolean           @default(false)
  createdAt          DateTime          @default(now())
  deliveries         CricketDelivery[]
  innings            CricketInnings    @relation(fields: [inningsId], references: [id], onDelete: Cascade)

  @@unique([inningsId, overNumber])
  @@map("cricket_overs")
}

model CricketDelivery {
  id                  String           @id @default(cuid())
  inningsId           String
  matchId             String
  overId              String
  overNumber          Int
  ballNumber          Int
  deliverySequence    Int
  bowlerId            String
  strikerId           String
  nonStrikerId        String
  deliveryType        DeliveryType
  runs                Int              @default(0)
  strikerRuns         Int              @default(0)
  nonStrikerRuns      Int              @default(0)
  isWicket            Boolean          @default(false)
  dismissalType       DismissalType?
  dismissedPlayerId   String?
  fielderId           String?
  bowlerCredited      Boolean          @default(true)
  isBye               Boolean          @default(false)
  isLegBye            Boolean          @default(false)
  isFreeHit           Boolean          @default(false)
  status              DeliveryStatus   @default(PENDING)
  submittedByPlayerId String
  confirmedByPlayerId String?
  createdAt           DateTime         @default(now())
  innings             CricketInnings   @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  over                CricketOver      @relation(fields: [overId], references: [id], onDelete: Cascade)
  disputes            CricketDispute[]

  @@map("cricket_deliveries")
}

model BattingPerformance {
  id                   String         @id @default(cuid())
  inningsId            String
  matchId              String
  playerId             String
  battingPosition      Int
  runs                 Int            @default(0)
  ballsFaced           Int            @default(0)
  fours                Int            @default(0)
  sixes                Int            @default(0)
  strikeRate           Float?
  dismissalType        DismissalType?
  dismissedByBowlerId  String?
  dismissedByFielderId String?
  isOut                Boolean        @default(false)
  notOut               Boolean        @default(true)
  hasBatted            Boolean        @default(false)
  createdAt            DateTime       @default(now())
  innings              CricketInnings @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  player               Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([inningsId, playerId])
  @@map("batting_performances")
}

model BowlingPerformance {
  id         String         @id @default(cuid())
  inningsId  String
  matchId    String
  playerId   String
  legalBalls Int            @default(0)
  runs       Int            @default(0)
  wickets    Int            @default(0)
  wides      Int            @default(0)
  noBalls    Int            @default(0)
  economy    Float?
  createdAt  DateTime       @default(now())
  innings    CricketInnings @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  player     Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([inningsId, playerId])
  @@map("bowling_performances")
}

model CricketMatchSignOff {
  id          String             @id @default(cuid())
  matchId     String
  inningsId   String?
  teamId      String
  type        CricketSignOffType
  signedOffAt DateTime           @default(now())
  innings     CricketInnings?    @relation(fields: [inningsId], references: [id], onDelete: Cascade)

  @@map("cricket_match_signoffs")
}

model CricketDispute {
  id             String          @id @default(cuid())
  deliveryId     String
  raisedByTeamId String
  reason         String?
  resolvedAt     DateTime?
  resolution     String?
  createdAt      DateTime        @default(now())
  delivery       CricketDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@map("cricket_disputes")
}

model Sponsor {
  id        String   @id @default(cuid())
  imageUrl  String
  ctaLink   String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  ctaText   String?

  @@map("sponsors")
}

model SponsorSettings {
  id         String   @id @default("singleton")
  autoSlide  Boolean  @default(true)
  intervalMs Int      @default(3500)
  updatedAt  DateTime @updatedAt

  @@map("sponsor_settings")
}

model Reel {
  id            String   @id @default(cuid())
  playerId      String
  muxUploadId   String?  @unique
  muxAssetId    String?  @unique
  muxPlaybackId String?
  status        String   @default("uploading")
  caption       String?
  views         Int      @default(0)
  likes         Int      @default(0)
  createdAt     DateTime @default(now())
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("reels")
}

model WbtTurf {
  id         String   @id @default(cuid())
  name       String
  divisionId String
  cityId     String
  createdAt  DateTime @default(now())
  city       City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@map("wbt_turfs")
}

model WbtCoupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  maxUses       Int          @default(0)
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())

  @@map("wbt_coupons")
}

model Organizer {
  id                  String                     @id @default(cuid())
  name                String
  email               String                     @unique
  phone               String                     @default("")
  password            String
  isVerified          Boolean                    @default(false)
  joinedAt            DateTime                   @default(now())
  inviteId            String?                    @unique
  chargePerTournament Int                        @default(0)
  banReason           String?
  banStatus           BanStatus                  @default(none)
  rechargeRequests    OrganizerRechargeRequest[]
  wallet              OrganizerWallet?
  invite              OrganizerInvite?           @relation(fields: [inviteId], references: [id])
  tournaments         Tournament[]

  @@map("organizers")
}

model OrganizerWallet {
  id            String                       @id @default(cuid())
  organizerId   String                       @unique
  balance       Float                        @default(0)
  totalToppedUp Float                        @default(0)
  totalSpent    Float                        @default(0)
  updatedAt     DateTime                     @updatedAt
  transactions  OrganizerWalletTransaction[]
  organizer     Organizer                    @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@map("organizer_wallets")
}

model OrganizerWalletTransaction {
  id          String          @id @default(cuid())
  organizerId String
  type        TOrgTxType
  amount      Float
  matchId     String?
  description String?
  createdAt   DateTime        @default(now())
  wallet      OrganizerWallet @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@map("organizer_wallet_transactions")
}

model OrganizerRechargeRequest {
  id               String               @id @default(cuid())
  organizerId      String
  amount           Float
  method           WalletRechargeMethod
  screenshotBase64 String?
  status           WalletRequestStatus  @default(pending)
  createdAt        DateTime             @default(now())
  organizer        Organizer            @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@map("organizer_recharge_requests")
}

model OrganizerInvite {
  id              String           @id @default(cuid())
  invitedBy       String
  emailOrPhone    String
  inviteToken     String           @unique @default(cuid())
  status          TOrgInviteStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  organizerUserId String?
  createdAt       DateTime         @default(now())
  organizer       Organizer?

  @@map("organizer_invites")
}

model Tournament {
  id                     String                   @id @default(cuid())
  operatorId             String
  operatorType           OperatorType
  sport                  TournamentSport
  name                   String
  description            String?
  bannerImageUrl         String?
  registrationType       TRegistrationType
  maxParticipants        Int
  entryFee               Int                      @default(0)
  registrationDeadline   DateTime?
  auctionEnabled         Boolean                  @default(false)
  playerBudgetPerCaptain Int?
  auctionStartTime       DateTime?
  prizePoolTotal         Int                      @default(0)
  prizeDistribution      Json                     @default("{}")
  prizeType              TPrizeType               @default(TROPHY_ONLY)
  formatType             TournamentFormat
  groupCount             Int?
  teamsPerGroup          Int?
  qualifyPerGroup        Int?
  mmrEnabled             Boolean                  @default(true)
  mmrMultiplier          Float                    @default(1.0)
  status                 TournamentStatus         @default(DRAFT)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  endDate                DateTime?
  startDate              DateTime?
  startTime              String?
  venue                  String?
  formatConfig           Json?
  formatConfigLocked     Boolean                  @default(false)
  isRegistrationOpen     Boolean                  @default(false)
  registrationOpenAt     DateTime?
  auctionRoom            AuctionRoom?
  groups                 TournamentGroup[]
  matches                TournamentMatch[]
  registrations          TournamentRegistration[]
  standings              TournamentStanding[]
  tournamentTeams        TournamentTeam[]
  organizer              Organizer                @relation(fields: [operatorId], references: [id])

  @@map("tournaments")
}

model TournamentRegistration {
  id           String              @id @default(cuid())
  tournamentId String
  entityType   TRegistrationType
  entityId     String
  registeredAt DateTime            @default(now())
  status       TRegistrationStatus @default(PENDING)
  entryFeePaid Boolean             @default(false)
  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, entityId])
  @@map("tournament_registrations")
}

model TournamentTeam {
  id           String     @id @default(cuid())
  tournamentId String
  captainId    String
  name         String
  players      String[]   @default([])
  budgetSpent  Int        @default(0)
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("tournament_teams")
}

model TournamentGroup {
  id           String               @id @default(cuid())
  tournamentId String
  name         String
  teamIds      String[]             @default([])
  tournament   Tournament           @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches      TournamentMatch[]
  standings    TournamentStanding[]

  @@map("tournament_groups")
}

model TournamentMatch {
  id            String                 @id @default(cuid())
  tournamentId  String
  groupId       String?
  stage         TMatchStage
  matchNumber   Int
  teamAId       String
  teamBId       String
  scheduledAt   DateTime?
  venue         String?
  scorerId      String?
  scorerType    TScorerType?
  matchMode     String                 @default("TOURNAMENT")
  status        TMatchStatus           @default(SCHEDULED)
  winnerId      String?
  resultSummary Json?
  disputeStatus TDisputeStatus         @default(PENDING)
  hasDispute    Boolean                @default(false)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  disputes      TournamentDispute[]
  group         TournamentGroup?       @relation(fields: [groupId], references: [id])
  tournament    Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  scorerToken   TournamentScorerToken?

  @@map("tournament_matches")
}

model TournamentScorerToken {
  id        String          @id @default(cuid())
  matchId   String          @unique
  token     String          @unique @default(cuid())
  scorerRef String?
  usedAt    DateTime?
  expiresAt DateTime?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  match     TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("tournament_scorer_tokens")
}

model TournamentStanding {
  id             String           @id @default(cuid())
  tournamentId   String
  groupId        String?
  teamId         String
  played         Int              @default(0)
  won            Int              @default(0)
  lost           Int              @default(0)
  drawn          Int              @default(0)
  noResult       Int              @default(0)
  points         Int              @default(0)
  nrr            Float            @default(0)
  goalDifference Int              @default(0)
  goalsScored    Int              @default(0)
  goalsConceded  Int              @default(0)
  headToHead     Json             @default("{}")
  position       Int              @default(0)
  qualified      Boolean          @default(false)
  updatedAt      DateTime         @updatedAt
  group          TournamentGroup? @relation(fields: [groupId], references: [id])
  tournament     Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, groupId, teamId])
  @@map("tournament_standings")
}

model TournamentDispute {
  id             String          @id @default(cuid())
  matchId        String
  raisedByTeamId String
  eventRef       String?
  reason         String
  status         TDisputeStatus  @default(PENDING)
  resolvedBy     String?
  resolutionNote String?
  raisedAt       DateTime        @default(now())
  resolvedAt     DateTime?
  match          TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("tournament_disputes")
}

model AuctionRoom {
  id                     String             @id @default(cuid())
  tournamentId           String             @unique
  status                 TAuctionRoomStatus @default(WAITING)
  currentPlayerId        String?
  currentBasePrice       Int?
  currentHighestBid      Int?
  currentHighestBidderId String?
  bidTimerSeconds        Int                @default(30)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  bids                   AuctionBid[]
  tournament             Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("auction_rooms")
}

model AuctionBid {
  id            String      @id @default(cuid())
  auctionRoomId String
  playerId      String
  captainId     String
  amount        Int
  timestamp     DateTime    @default(now())
  room          AuctionRoom @relation(fields: [auctionRoomId], references: [id], onDelete: Cascade)

  @@map("auction_bids")
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  purpose   String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, otp])
  @@map("otp_verifications")
}

model TurfServiceSetting {
  id        String    @id @default("singleton")
  isActive  Boolean   @default(false)
  launchAt  DateTime?
  updatedAt DateTime  @updatedAt

  @@map("turf_service_settings")
}

enum TurfStatus {
  pending
  published
  rejected
}

enum RevenueModelType {
  percentage
  monthly
}

enum SlotStatus {
  available
  walkin
  maintenance
  booked
}

enum TimeCategory {
  Morning
  Afternoon
  Evening
  Night
}

enum BookingStatus {
  confirmed
  cancelled
  completed
}

enum BanStatus {
  none
  soft
  perma
}

enum WalletRequestStatus {
  pending
  approved
  rejected
}

enum DisputeStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum PayoutMethod {
  bank
  bkash
  cash
}

enum WalletRechargeMethod {
  bkash
  nagad
  bank
}

enum LedgerEntryType {
  cost
  income
}

enum LedgerCategory {
  staff
  facility
  walkin
  other
}

enum DiscountType {
  percentage
  flat
}

enum InviteRole {
  TurfOwner
  Coach
}

enum VenueType {
  BMT
  OPEN_WBT
}

enum TeamRole {
  owner
  member
  manager
  captain
  vice_captain
}

enum SportType {
  FUTSAL_5
  FUTSAL_6
  CRICKET_7
  FUTSAL_7
  FOOTBALL_FULL
  CRICKET_FULL
}

enum ScoringMode {
  LIVE
  SCORE_AFTER
  LIVE_SINGLE
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  PENDING
  INTERACTION
  LIVE
  SCORE_ENTRY
  DISPUTED
}

enum BadgeType {
  NONE
  MVP
  THE_SNIPER
  THE_MAESTRO
  THE_WALL
  GOLDEN_BOOT
  MIDFIELD_GENERAL
  DEFENSIVE_ANCHOR
  SAFE_HANDS
  POWER_HITTER
  IMPACT_BOWLER
  GAME_CHANGER
  THE_ANCHOR
  STRIKE_BOWLER
  ECONOMY_MASTER
  GOLDEN_GLOVE
}

enum MatchEventType {
  GOAL
  OWN_GOAL
  PENALTY_SCORED
  PENALTY_MISSED
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  HALF_TIME
  FULL_TIME
}

enum EventStatus {
  PENDING
  CONFIRMED
  DISPUTED
  REMOVED
}

enum DeliveryType {
  LEGAL
  WIDE
  NO_BALL
}

enum DeliveryStatus {
  PENDING
  CONFIRMED
  CONFLICTED
  LOCKED
  VOIDED
}

enum DismissalType {
  BOWLED
  CAUGHT
  LBW
  RUN_OUT
  STUMPED
  HIT_WICKET
}

enum InningsStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SIGNED_OFF
}

enum OverStatus {
  PENDING
  CONFIRMED
}

enum CricketSignOffType {
  INNINGS
  MATCH
}

enum TeamType {
  REGULAR
  TOURNAMENT
}

enum PlaySplitStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum PlayJoinStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  AUCTION_PENDING
  AUCTION_LIVE
  AUCTION_COMPLETED
  DRAFTING
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TournamentSport {
  CRICKET
  FOOTBALL
}

enum TournamentFormat {
  LEAGUE
  KNOCKOUT
  GROUP_KNOCKOUT
  DOUBLE_ELIMINATION
}

enum TRegistrationType {
  TEAM
  PLAYER
}

enum TPrizeType {
  APP_COINS
  REAL_MONEY
  TROPHY_ONLY
}

enum TMatchStatus {
  SCHEDULED
  SCORER_ASSIGNED
  LIVE
  COMPLETED
  WALKOVER
  POSTPONED
  CANCELLED
}

enum TMatchStage {
  GROUP
  ROUND_OF_16
  QUARTER
  SEMI
  FINAL
  THIRD_PLACE
}

enum TScorerType {
  ASSIGNED
  ORGANIZER
  ADMIN
}

enum OperatorType {
  PLATFORM
  ORGANIZER
}

enum TOrgInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum TAuctionRoomStatus {
  WAITING
  LIVE
  PAUSED
  COMPLETED
}

enum TOrgTxType {
  TOP_UP
  MATCH_CHARGE
  REFUND
  TOURNAMENT_CHARGE
}

enum TDisputeStatus {
  PENDING
  REVIEWING
  UPHELD
  REJECTED
}

enum TRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}
